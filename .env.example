# =============================================================================
# Competitor Intelligence Monitor - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=compmon
POSTGRES_PASSWORD=changeme
POSTGRES_DB=compmon
DATABASE_URL=postgresql+asyncpg://compmon:changeme@postgres:5432/compmon
DATABASE_URL_SYNC=postgresql://compmon:changeme@postgres:5432/compmon

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=compmon
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_INITDB_DATABASE=compmon
MONGODB_URL=mongodb://compmon:changeme@mongodb:27017/compmon?authSource=admin

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_RESULT_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS_BUDGET=4000
CLAUDE_RATE_LIMIT_PER_MINUTE=20

# --- SendGrid ---
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=alerts@yourcompany.com

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging ---
LOG_LEVEL=info

# --- App ---
APP_NAME=Competitor Intelligence Monitor
APP_VERSION=0.1.0
DEFAULT_CHECK_INTERVAL_HOURS=6
MAX_MONITORS_PER_USER=50
SCRAPE_BATCH_SIZE=20
SNAPSHOT_TTL_DAYS=90
